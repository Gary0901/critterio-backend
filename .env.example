# 伺服器
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# AI（每日照護建議、AI 聊天助理主要使用 Groq；OpenAI/Gemini 目前備用/未啟用）
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Cloudinary（貼文/寵物頭像圖片儲存）
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google 登入 / 地圖地理編碼
# GOOGLE_OAUTH_CLIENT_IDS 可用逗號分隔多個 client id（iOS/Android/Web）
GOOGLE_OAUTH_CLIENT_IDS=your_google_oauth_client_ids
GOOGLE_GEOCODING_KEY=your_google_geocoding_api_key

# Resend（忘記密碼等系統信件；需先完成網域驗證才能寄給所有使用者）
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Critterio <noreply@yourdomain.com>

# App 深層連結 scheme（Google 登入 callback 用，預設 critterio）
APP_SCHEME=critterio

# Admin 後台簡易驗證（/api/v1/admin/* 用 x-admin-secret header 或 ?secret= 帶入）
ADMIN_SECRET=your_admin_secret_here
